# Copy to .env and fill in values, then source it: source .env
# .env is gitignored — never commit real tokens

# GitHub Personal Access Token (classic)
# Create at: https://github.com/settings/tokens/new
# Required scopes: read:packages + repo
export GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXX

# GitHub username (image owner)
export GHCR_USERNAME=ybojko

# Database
export POSTGRES_PASSWORD=dev-password-change-me

# Grafana OAuth client secret (any random string for local)
export GRAFANA_OAUTH_CLIENT_SECRET=local-dev-grafana-secret
