# Copy to .env and fill in values, then source it: source .env
# .env is gitignored — never commit real tokens

# GitHub Container Registry — PAT with read:packages scope
export GHCR_USERNAME=ybojko
export GHCR_PASSWORD=ghp_XXXXXXXXXXXXXXXXXXXX

# GitHub token for ArgoCD to read voting-app-gitops (private repo)
export GITOPS_REPO_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXX

# Database
export POSTGRES_PASSWORD=dev-password-change-me

# Grafana OAuth client secret (any random string for local)
export GRAFANA_OAUTH_CLIENT_SECRET=local-dev-grafana-secret

# Cloudflare API token (optional — only needed if testing DNS locally)
export CLOUDFLARE_API_TOKEN=cfut_XXXXXXXXXXXXXXXXXXXX
